{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://suture.local/schemas/discharge_ground_truth.schema.json",
  "title": "Discharge summary ground truth",
  "description": "Canonical extraction values for a single synthetic discharge summary PDF.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document_external_id",
    "classification",
    "discharge_type",
    "patient",
    "discharging_hospital",
    "attending_physician",
    "admit_date",
    "discharge_date",
    "primary_diagnosis",
    "diagnosis_codes",
    "procedures_performed",
    "medications_changed",
    "follow_up_window_days",
    "recommended_specialist",
    "urgent_flags",
    "urgency_tier",
    "missing_fields",
    "is_degraded"
  ],
  "properties": {
    "document_external_id": {"type": "string", "pattern": "^DIS-[0-9]{3}$"},
    "classification": {"type": "string", "const": "discharge_summary"},
    "discharge_type": {
      "type": "string",
      "enum": ["post_mi", "post_chf", "post_cath", "post_ablation"]
    },
    "patient": {"$ref": "#/$defs/patient"},
    "discharging_hospital": {"type": "string"},
    "attending_physician": {
      "type": "object",
      "additionalProperties": false,
      "required": ["first_name", "last_name", "npi"],
      "properties": {
        "first_name": {"type": "string"},
        "last_name": {"type": "string"},
        "npi": {"type": "string", "pattern": "^[0-9]{10}$"}
      }
    },
    "admit_date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    "discharge_date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    "primary_diagnosis": {"type": "string", "minLength": 1},
    "diagnosis_codes": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    },
    "procedures_performed": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["description", "cpt_code"],
        "properties": {
          "description": {"type": "string"},
          "cpt_code": {"type": ["string", "null"]}
        }
      }
    },
    "medications_changed": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "action"],
        "properties": {
          "name": {"type": "string"},
          "action": {"type": "string", "enum": ["started", "stopped", "adjusted"]}
        }
      }
    },
    "follow_up_window_days": {"type": "integer"},
    "recommended_specialist": {"type": "string", "const": "Cardiology"},
    "urgent_flags": {
      "type": "array",
      "items": {"type": "string"}
    },
    "urgency_tier": {
      "type": "string",
      "enum": ["critical", "high", "medium", "routine"]
    },
    "missing_fields": {
      "type": "array",
      "items": {"type": "string"}
    },
    "is_degraded": {"type": "boolean"}
  },
  "$defs": {
    "patient": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "external_id",
        "first_name",
        "last_name",
        "dob",
        "phone",
        "address_line1",
        "city",
        "state",
        "zip_code",
        "mrn"
      ],
      "properties": {
        "external_id": {"type": "string", "pattern": "^PAT-[0-9]{3}$"},
        "first_name": {"type": "string"},
        "last_name": {"type": "string"},
        "dob": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
        "phone": {"type": ["string", "null"]},
        "address_line1": {"type": ["string", "null"]},
        "city": {"type": ["string", "null"]},
        "state": {"type": ["string", "null"]},
        "zip_code": {"type": ["string", "null"]},
        "mrn": {"type": ["string", "null"]}
      }
    }
  }
}
