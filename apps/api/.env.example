# Copy to .env (do NOT commit). Generate secrets with `make gen-phi-key` and `make gen-jwt-keys`.

# Database
DATABASE_URL=postgresql+asyncpg://suture:suture_dev_password@localhost:5432/suture

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth (generate with `make gen-jwt-keys`)
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_SECONDS=3600
JWT_REFRESH_TOKEN_TTL_SECONDS=2592000

# PHI encryption (generate with `make gen-phi-key`)
PHI_ENCRYPTION_KEY=

# Observability
OTEL_DISABLED=1
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=suture-api

# LLM provider (BYOK; defaults to local Ollama — see ADR 007)
# Options: ollama | openai | anthropic
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=medgemma1.5

# Embedding provider (BYOK; defaults to local Ollama bge-m3, 1024-dim)
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=bge-m3

# Optional BYOK keys — uncomment + populate to use cloud providers.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-5

# Logging
LOG_LEVEL=INFO
