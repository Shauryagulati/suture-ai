# No API keys needed for normal use. Synthetic data reads from committed
# fixtures at seeds/scripts/llm_fixtures/. CI does not need any key.
#
# To regenerate fixtures (rare — only when prompts or data shape change):
#   export SUTURE_ALLOW_LIVE_LLM=1
#   export ANTHROPIC_API_KEY=sk-ant-...
#   make seed-synthetic
#
# Cost cap is $5.00, enforced by FixtureBackedClaude. See ADR 007.
