# Uploaded documents land here at runtime (per-clinic subdirs under apps/api/data/documents/).
data/
# NOTE: seeds/documents/*.pdf is COMMITTED — they are ground-truth fixtures for the eval harness.
# Do NOT re-add gitignore lines for those PDFs.

# Transient atomic-write lockfiles for LLM fixtures (fixtures themselves ARE committed)
seeds/scripts/llm_fixtures/in_flight/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Logs
*.log
logs/
# Exception: generation.log is a committed artifact documenting the synthetic-data generation run.
!seeds/scripts/generation.log

# Docker volumes (compose puts these in named volumes already, just in case)
infra/data/

# Runtime artifacts written by the API at request time (prior-auth packet/appeal
# PDFs land here). Local-dev only; production swaps for S3.
apps/api/var/
apps/var/

# Eval harness run output — generated artifacts, regenerated by `make eval-extraction`.
ai/evals/results/

# Personal notes / walkthroughs — not part of the repo
FOUNDATION_WALKTHROUGH.md
